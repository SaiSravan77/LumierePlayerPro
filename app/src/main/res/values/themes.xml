<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.LumierePlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#c9a84c</item>
        <item name="colorPrimaryVariant">#7a6229</item>
        <item name="colorOnPrimary">#080808</item>
        <item name="colorSecondary">#c9a84c</item>
        <item name="colorSurface">#0e0e0e</item>
        <item name="colorOnSurface">#e8e0d0</item>
        <item name="android:windowBackground">#080808</item>
        <item name="android:statusBarColor">#080808</item>
        <item name="android:navigationBarColor">#080808</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:textColor">#e8e0d0</item>
    </style>

    <!-- Dark dialog -->
    <style name="DialogDark" parent="Theme.MaterialComponents.Dialog">
        <item name="colorSurface">#0e0e0e</item>
        <item name="colorOnSurface">#e8e0d0</item>
        <item name="colorPrimary">#c9a84c</item>
        <item name="android:textColor">#e8e0d0</item>
        <item name="android:background">#0e0e0e</item>
    </style>

    <!-- Preset chip -->
    <style name="PresetChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textColor">@drawable/chip_text_color</item>
        <item name="android:background">@drawable/chip_background</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Toolbar -->
    <style name="LumiereToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">#0e0e0e</item>
        <item name="titleTextColor">#c9a84c</item>
    </style>

</resources>
