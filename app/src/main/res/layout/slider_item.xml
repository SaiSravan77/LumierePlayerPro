<?xml version="1.0" encoding="utf-8"?>
<!-- slider_item.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:layout_marginBottom="8dp">
    <com.google.android.material.slider.Slider
        android:id="@+id/sliderSeek"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:valueFrom="0" android:valueTo="100" android:value="50"
        app:thumbColor="#c9a84c" app:trackColorActive="#c9a84c"
        app:trackColorInactive="#1a1a1a" app:thumbRadius="6dp" app:trackHeight="2dp"/>
</LinearLayout>
