<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- VIDEO SURFACE -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:use_controller="false"
        app:surface_type="surface_view"
        android:visibility="invisible"/>

    <!-- LOADING -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="#c9a84c"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- EMPTY STATE -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="▶" android:textSize="56sp" android:textColor="#2a2520" android:gravity="center"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="TAP TO OPEN A VIDEO" android:textSize="12sp" android:letterSpacing="0.25"
            android:textColor="#3a3530" android:layout_marginTop="16dp" android:gravity="center"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="MP4 · MKV · AVI · MOV · WebM" android:textSize="10sp"
            android:textColor="#2a2520" android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- GESTURE OVERLAY -->
    <include layout="@layout/overlay_gesture"
        android:id="@+id/gestureOverlay"
        android:layout_width="160dp"
        android:layout_height="80dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ENHANCE BADGE -->
    <TextView
        android:id="@+id/enhanceBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✦ 4K ENHANCED"
        android:textSize="9sp"
        android:letterSpacing="0.15"
        android:textColor="#c9a84c"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:paddingTop="4dp" android:paddingBottom="4dp"
        android:background="@drawable/badge_border"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CONTROLS OVERLAY -->
    <LinearLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:background="@drawable/controls_gradient"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Filename -->
        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No file loaded"
            android:textColor="#99e8e0d0"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="middle"
            android:layout_marginBottom="8dp"/>

        <!-- Seek bar -->
        <com.google.android.material.slider.Slider
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="1000"
            android:value="0"
            app:thumbColor="#c9a84c"
            app:trackColorActive="#c9a84c"
            app:trackColorInactive="#33ffffff"
            app:thumbRadius="6dp"
            app:trackHeight="3dp"
            android:layout_marginBottom="4dp"/>

        <!-- Controls row -->
        <LinearLayout
            android:id="@+id/controlsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton android:id="@+id/btnPrev" android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_skip_previous" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
            <ImageButton android:id="@+id/btnSkipBack" android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_replay_10" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
            <ImageButton android:id="@+id/btnPlayPause" android:layout_width="48dp" android:layout_height="48dp"
                android:src="@drawable/ic_play" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#c9a84c"/>
            <ImageButton android:id="@+id/btnSkipFwd" android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_forward_10" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
            <ImageButton android:id="@+id/btnNext" android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_skip_next" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>

            <TextView android:id="@+id/tvTime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0:00 / 0:00" android:textColor="#99e8e0d0" android:textSize="11sp"
                android:fontFamily="monospace" android:layout_marginStart="8dp"/>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <Button android:id="@+id/btnSpeed" android:layout_width="wrap_content" android:layout_height="28dp"
                android:text="1×" android:textSize="10sp" android:textColor="#e8e0d0"
                style="@style/Widget.MaterialComponents.Button.TextButton" android:minWidth="0dp" android:paddingStart="6dp" android:paddingEnd="6dp"/>
            <Button android:id="@+id/btnAspect" android:layout_width="wrap_content" android:layout_height="28dp"
                android:text="Fit" android:textSize="10sp" android:textColor="#e8e0d0"
                style="@style/Widget.MaterialComponents.Button.TextButton" android:minWidth="0dp" android:paddingStart="6dp" android:paddingEnd="6dp"/>
            <ImageButton android:id="@+id/btnAudio" android:layout_width="32dp" android:layout_height="32dp"
                android:src="@drawable/ic_audio_track" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
            <ImageButton android:id="@+id/btnSub" android:layout_width="32dp" android:layout_height="32dp"
                android:src="@drawable/ic_subtitles" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
            <ImageButton android:id="@+id/btnScreenshot" android:layout_width="32dp" android:layout_height="32dp"
                android:src="@drawable/ic_screenshot" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
            <ImageButton android:id="@+id/btnLock" android:layout_width="32dp" android:layout_height="32dp"
                android:src="@drawable/ic_lock_open" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
            <ImageButton android:id="@+id/btnFullscreen" android:layout_width="32dp" android:layout_height="32dp"
                android:src="@drawable/ic_fullscreen" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ENHANCE PANEL CONTAINER -->
    <FrameLayout
        android:id="@+id/enhancePanelContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <include layout="@layout/panel_enhance" android:id="@+id/enhancePanel"/>
    </FrameLayout>

    <!-- EQ PANEL CONTAINER -->
    <FrameLayout
        android:id="@+id/eqPanelContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <include layout="@layout/panel_equalizer" android:id="@+id/eqPanel"/>
    </FrameLayout>

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#0e0e0e"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="LUMIÈRE" android:textColor="#c9a84c" android:textSize="13sp"
            android:letterSpacing="0.2" android:layout_marginEnd="12dp"/>

        <View android:layout_width="1dp" android:layout_height="16dp" android:background="#2a2a2a" android:layout_marginEnd="12dp"/>

        <HorizontalScrollView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:scrollbars="none">
            <LinearLayout android:id="@+id/presetsRowBottom" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical"/>
        </HorizontalScrollView>

        <View android:layout_width="1dp" android:layout_height="16dp" android:background="#2a2a2a" android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>

        <ImageButton android:id="@+id/btnEnhance" android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_enhance" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#c9a84c"/>
        <ImageButton android:id="@+id/btnEq" android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_equalizer" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
        <ImageButton android:id="@+id/btnPlaylist" android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_playlist" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
        <ImageButton android:id="@+id/btnLibrary" android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_library" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>
        <ImageButton android:id="@+id/btnSettings" android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_settings" android:background="?attr/selectableItemBackgroundBorderless" android:tint="#e8e0d0"/>

        <View android:layout_width="1dp" android:layout_height="16dp" android:background="#2a2a2a" android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>

        <Button android:id="@+id/btnOpen" android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="OPEN" android:textSize="10sp" android:letterSpacing="0.1" android:textColor="#c9a84c"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#7a6229" android:paddingStart="12dp" android:paddingEnd="12dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
